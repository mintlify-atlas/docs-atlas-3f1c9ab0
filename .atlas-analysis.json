  "keyFeatures": [
    "Intel TDX attestation with DCAP verification",
    "RA-TLS (Remote Attestation TLS) for cryptographically verified connections",
    "EKM channel binding with HMAC-SHA256 for TLS security",
    "Next.js frontend with streaming chat interface",
    "Confidential Virtual Machine services on Phala Cloud",
    "PDF document processing in trusted execution environment",
    "Supabase authentication with role-based access control",
    "Prometheus + Grafana monitoring for vLLM metrics"
  ],
  "publicApiSurface": [
    "GET /health - Attestation service health check",
    "POST /tdx_quote - Generate TDX attestation quote",
    "POST /api/waitlist - Submit waitlist request",
    "POST /api/feedback - Submit user feedback",
    "GET /api/form-token - Generate HMAC-signed form token",
    "POST /api/chat/completions - Proxy OpenAI-compatible streaming requests",
    "GET /api/admin/waitlist - List waitlist requests (admin)",
    "POST /api/admin/waitlist/[id]/activate - Activate waitlist user (admin)"
  ]
